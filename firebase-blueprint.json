{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "password": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Individual sales records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "platform": { "type": "string", "enum": ["in-store", "iFood", "99food"] },
        "paymentMethod": { "type": "string", "enum": ["pix", "cash", "ted"] },
        "pixKeyUsed": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "timestamp": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "sender": { "type": "string" },
        "recipient": { "type": "string" }
      },
      "required": ["amount", "platform", "paymentMethod", "timestamp"]
    },
    "InventoryItem": {
      "title": "Inventory Item",
      "description": "Items in the warehouse",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "minStock": { "type": "number" },
        "supplierId": { "type": "string" }
      },
      "required": ["name", "quantity"]
    },
    "InventoryTransaction": {
      "title": "Inventory Transaction",
      "description": "Stock entries (invoices) and exits (orders)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "itemId": { "type": "string" },
        "type": { "type": "string", "enum": ["entry", "exit"] },
        "quantity": { "type": "number" },
        "invoiceNumber": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["itemId", "type", "quantity", "timestamp"]
    },
    "FinancialRecord": {
      "title": "Financial Record",
      "description": "Income, expenses, accounts payable/receivable",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense", "payable", "receivable"] },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["pending", "paid"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "amount", "timestamp"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Vendor information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "contact": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["name"]
    },
    "Closure": {
      "title": "Closure",
      "description": "Periodic financial closures",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["decadal", "monthly", "annual"] },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "totalSales": { "type": "number" },
        "totalExpenses": { "type": "number" },
        "netProfit": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "startDate", "endDate", "totalSales", "totalExpenses"]
    },
    "PaymentSettings": {
      "title": "Payment Settings",
      "description": "Configuration for Pix and TED payments",
      "type": "object",
      "properties": {
        "pixKeys": { "type": "array", "items": { "type": "string" } },
        "tedAccounts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "bank": { "type": "string" },
              "agency": { "type": "string" },
              "account": { "type": "string" },
              "owner": { "type": "string" }
            }
          }
        }
      }
    },
    "BusinessSettings": {
      "title": "Business Settings",
      "description": "General business information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "taxId": { "type": "string" }
      },
      "required": ["name", "address", "phone", "email", "taxId"]
    },
    "GeneralSettings": {
      "title": "General Settings",
      "description": "Visual and operational settings",
      "type": "object",
      "properties": {
        "darkMode": { "type": "boolean" },
        "openSaleOnStart": { "type": "boolean" },
        "closeOnRestaurantClose": { "type": "boolean" }
      }
    },
    "NotificationLog": {
      "title": "Notification Log",
      "description": "Log of system events",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["system_open", "system_close", "receipt_generated", "invoice_generated", "payment_received"] },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "operatorName": { "type": "string" }
      }
    },
    "Integration": {
      "title": "Integration",
      "description": "External service integration",
      "type": "object",
      "properties": {
        "provider": { "type": "string" },
        "type": { "type": "string", "enum": ["government", "private"] },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "apiKey": { "type": "string" },
        "endpoint": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/sales/{saleId}": { "schema": "Sale", "description": "Sales records" },
    "/inventory/{itemId}": { "schema": "InventoryItem", "description": "Current stock" },
    "/inventoryTransactions/{txId}": { "schema": "InventoryTransaction", "description": "Stock movements" },
    "/financials/{recordId}": { "schema": "FinancialRecord", "description": "Accounting records" },
    "/suppliers/{supplierId}": { "schema": "Supplier", "description": "Vendor list" },
    "/closures/{closureId}": { "schema": "Closure", "description": "Financial reports" },
    "/settings/{settingId}": { "schema": "PaymentSettings | BusinessSettings | GeneralSettings", "description": "Global application settings" },
    "/notifications/{notificationId}": { "schema": "NotificationLog", "description": "System event logs" },
    "/integrations/{integrationId}": { "schema": "Integration", "description": "External service settings" }
  }
}
